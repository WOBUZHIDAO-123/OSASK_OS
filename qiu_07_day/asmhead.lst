     1 00000000                                 ; haribote-os boot asm
     2 00000000                                 ; TAB=4
     3 00000000                                 
     4 00000000                                 ; ============================================================
     5 00000000                                 ; 常量定义
     6 00000000                                 ; ============================================================
     7  = 00280000                              BOTPAK  EQU     0x00280000      ; bootpack 的加载目标地址（内存高端，避开 BIOS/显存区域）
     8  = 00100000                              DSKCAC  EQU     0x00100000      ; 磁盘缓存存放位置（将整个磁盘映像复制到这里）
     9  = 00008000                              DSKCAC0 EQU     0x00008000      ; 磁盘缓存存放位置（实模式阶段，先暂存到低端内存）
    10 00000000                                 
    11 00000000                                 ; ============================================================
    12 00000000                                 ; BOOT_INFO 相关定义（由引导扇区 IPL 写入，供内核读取）
    13 00000000                                 ; ============================================================
    14  = 00000FF0                              CYLS    EQU     0x0ff0          ; IPL 探测到的柱面数（Cylinders），引导扇区设置
    15  = 00000FF1                              LEDS    EQU     0x0ff1          ; 键盘 LED 状态（Num Lock / Caps Lock 等）
    16  = 00000FF2                              VMODE   EQU     0x0ff2          ; 显示模式信息（多少位色彩等）
    17  = 00000FF4                              SCRNX   EQU     0x0ff4          ; 屏幕分辨率 X（水平像素数）
    18  = 00000FF6                              SCRNY   EQU     0x0ff6          ; 屏幕分辨率 Y（垂直像素数）
    19  = 00000FF8                              VRAM    EQU     0x0ff8          ; 显存（VRAM）起始地址
    20 00000000                                 
    21 00000000                                 ; -----------------------------------------------------------
    22 00000000                                 ; 代码入口：本程序由 IPL 加载到 0xc200 处并跳转至此执行
    23 00000000                                 ; -----------------------------------------------------------
    24                                                  ORG     0xc200          ; 指定程序加载地址为 0xc200
    25 0000C200                                 
    26 0000C200                                 ; -----------------------------------------------------------
    27 0000C200                                 ; 设置显示模式（VGA 图形模式 320×200×8bit 彩色）
    28 0000C200                                 ; -----------------------------------------------------------
    29 0000C200 B0 13                                   MOV     AL, 0x13        ; VGA 模式 0x13：320×200×8 位彩色（256 色）
    30 0000C202 B4 00                                   MOV     AH, 0x00        ; 功能号 0x00：设置显示模式
    31 0000C204 CD 10                                   INT     0x10            ; 调用 BIOS 视频中断
    32 0000C206                                         ; 将显示模式参数保存到 BOOT_INFO 区域，供 C 语言内核引用
    33 0000C206 C6 06 0FF2 08                           MOV     BYTE [VMODE], 8     ; 保存色彩位数：8 位（256 色）
    34 0000C20B C7 06 0FF4 0140                         MOV     WORD [SCRNX], 320   ; 保存水平分辨率：320
    35 0000C211 C7 06 0FF6 00C8                         MOV     WORD [SCRNY], 200   ; 保存垂直分辨率：200
    36 0000C217 66 C7 06 0FF8 000A0000                  MOV     DWORD [VRAM], 0x000a0000  ; 保存显存基址：0xA0000
    37 0000C220                                 
    38 0000C220                                 ; -----------------------------------------------------------
    39 0000C220                                 ; 获取键盘 LED 状态（从 BIOS 读取并保存）
    40 0000C220                                 ; -----------------------------------------------------------
    41 0000C220 B4 02                                   MOV     AH, 0x02        ; 功能号 0x02：读取键盘标志字节（含 LED 状态）
    42 0000C222 CD 16                                   INT     0x16            ; 调用键盘 BIOS 中断
    43 0000C224 A2 0FF1                                 MOV     [LEDS], AL      ; 将 LED 状态保存到 BOOT_INFO 区域
    44 0000C227                                 
    45 0000C227                                 ; -----------------------------------------------------------
    46 0000C227                                 ; 暂时屏蔽 PIC（可编程中断控制器），禁止所有硬件中断
    47 0000C227                                 ; 按照 AT 兼容机规范，如果要对 PIC 进行初始化，
    48 0000C227                                 ; 必须在 CLI 之前先屏蔽 PIC，否则偶尔会挂死。
    49 0000C227                                 ; PIC 的正式初始化稍后再做。
    50 0000C227                                 ; -----------------------------------------------------------
    51 0000C227 B0 FF                                   MOV     AL, 0xff        ; 所有位设为 1，屏蔽全部 IRQ
    52 0000C229 E6 21                                   OUT     0x21, AL        ; 写入主 PIC 的 IMR 寄存器（端口 0x21）
    53 0000C22B 90                                      NOP                     ; 连续 OUT 指令在某些机型上可能导致问题，插入 NOP 延迟
    54 0000C22C E6 A1                                   OUT     0xa1, AL        ; 写入从 PIC 的 IMR 寄存器（端口 0xA1）
    55 0000C22E                                 
    56 0000C22E FA                                      CLI                     ; 禁止 CPU 级中断响应（清除 EFLAGS 的 IF 位）
    57 0000C22F                                 
    58 0000C22F                                 ; -----------------------------------------------------------
    59 0000C22F                                 ; 启用 A20 地址线，使 CPU 能够访问 1MB 以上的内存
    60 0000C22F                                 ; 通过键盘控制器（8042）的端口操作实现
    61 0000C22F                                 ; -----------------------------------------------------------
    62 0000C22F E8 00B5                                 CALL    waitkbdout      ; 等待键盘控制器输出缓冲区空闲
    63 0000C232 B0 D1                                   MOV     AL, 0xd1        ; 命令 0xD1：准备向键盘控制器写输出端口
    64 0000C234 E6 64                                   OUT     0x64, AL        ; 发送命令到状态端口 0x64
    65 0000C236 E8 00AE                                 CALL    waitkbdout      ; 等待命令被接受
    66 0000C239 B0 DF                                   MOV     AL, 0xdf        ; 数据 0xDF：设置输出端口 bit1 = 1（启用 A20）
    67 0000C23B E6 60                                   OUT     0x60, AL        ; 写入数据端口 0x60
    68 0000C23D E8 00A7                                 CALL    waitkbdout      ; 等待操作完成
    69 0000C240                                 
    70 0000C240                                 ; -----------------------------------------------------------
    71 0000C240                                 ; 切换到保护模式（Protected Mode）
    72 0000C240                                 ; -----------------------------------------------------------
    73 0000C240                                 [INSTRSET "i486p"]              ; 告知汇编器允许使用 486 指令集
    74 0000C240                                 
    75 0000C240 0F 01 16 C32A                           LGDT    [GDTR0]         ; 加载全局描述符表寄存器（GDTR），设置临时 GDT
    76 0000C245                                 
    77 0000C245                                         ; 修改 CR0 寄存器以启用保护模式
    78 0000C245 0F 20 C0                                MOV     EAX, CR0        ; 读取当前 CR0 值
    79 0000C248 66 25 7FFFFFFF                          AND     EAX, 0x7fffffff ; 将 bit31（分页使能位）清零，禁止分页
    80 0000C24E 66 83 C8 01                             OR      EAX, 0x00000001 ; 将 bit0（保护模式使能位）置 1
    81 0000C252 0F 22 C0                                MOV     CR0, EAX        ; 写回 CR0，此时 CPU 进入保护模式
    82 0000C255                                 
    83 0000C255                                         ; 通过远跳转清空 CPU 流水线，确保后续指令在保护模式下正确解码
    84 0000C255 EB 00                                   JMP     pipelineflush
    85 0000C257                                 pipelineflush:
    86 0000C257                                 
    87 0000C257                                         ; 设置段寄存器，指向 GDT 中的第 1 个段描述符（可读写数据段，32 位）
    88 0000C257 B8 0008                                 MOV     AX, 1*8         ; 段选择子：索引=1，TI=0（GDT），RPL=0
    89 0000C25A 8E D8                                   MOV     DS, AX
    90 0000C25C 8E C0                                   MOV     ES, AX
    91 0000C25E 8E E0                                   MOV     FS, AX
    92 0000C260 8E E8                                   MOV     GS, AX
    93 0000C262 8E D0                                   MOV     SS, AX
    94 0000C264                                 
    95 0000C264                                 ; -----------------------------------------------------------
    96 0000C264                                 ; 将 bootpack 从当前内存位置复制到目标地址 BOTPAK（0x280000）
    97 0000C264                                 ; -----------------------------------------------------------
    98 0000C264 66 BE 0000C330                          MOV     ESI, bootpack   ; 源地址：bootpack 标签处（当前紧跟在本程序后的数据）
    99 0000C26A 66 BF 00280000                          MOV     EDI, BOTPAK     ; 目标地址：0x00280000
   100 0000C270 66 B9 00020000                          MOV     ECX, 512*1024/4 ; 复制大小：512KB，以双字（4字节）为单位计数
   101 0000C276 E8 0075                                 CALL    memcpy          ; 调用内存复制子程序
   102 0000C279                                 
   103 0000C279                                 ; -----------------------------------------------------------
   104 0000C279                                 ; 将磁盘数据也转移到最终的内存位置（磁盘缓存区 DSKCAC）
   105 0000C279                                 ; 首先复制引导扇区（IPL）
   106 0000C279                                 ; -----------------------------------------------------------
   107 0000C279 66 BE 00007C00                          MOV     ESI, 0x7c00     ; 源地址：BIOS 加载 IPL 的固定地址 0x7C00
   108 0000C27F 66 BF 00100000                          MOV     EDI, DSKCAC     ; 目标地址：0x00100000（磁盘缓存区起始）
   109 0000C285 66 B9 00000080                          MOV     ECX, 512/4      ; 复制 512 字节（一个扇区），以双字计数
   110 0000C28B E8 0060                                 CALL    memcpy
   111 0000C28E                                 
   112 0000C28E                                 ; -----------------------------------------------------------
   113 0000C28E                                 ; 复制磁盘剩余的全部内容到缓存区
   114 0000C28E                                 ; -----------------------------------------------------------
   115 0000C28E 66 BE 00008200                          MOV     ESI, DSKCAC0+512    ; 源地址：实模式暂存区（0x8000）+512 字节偏移
   116 0000C294 66 BF 00100200                          MOV     EDI, DSKCAC+512     ; 目标地址：磁盘缓存区（0x100000）+512 字节偏移
   117 0000C29A 66 B9 00000000                          MOV     ECX, 0
   118 0000C2A0 8A 0E 0FF0                              MOV     CL, BYTE [CYLS]     ; 读取 IPL 探测到的柱面数
   119 0000C2A4                                         ; 将柱面数转换为字节数：柱面数 × (磁头数2 × 每道扇区数18 × 512) / 4
   120 0000C2A4 66 69 C9 00001200                       IMUL    ECX, 512*18*2/4     ; 得出总双字数
   121 0000C2AB 66 81 E9 00000080                       SUB     ECX, 512/4          ; 减去 IPL 扇区（已单独复制），得到剩余数据量
   122 0000C2B2 E8 0039                                 CALL    memcpy
   123 0000C2B5                                 
   124 0000C2B5                                 ; -----------------------------------------------------------
   125 0000C2B5                                 ; asmhead 中必须完成的工作已全部结束，后续交给 bootpack 处理
   126 0000C2B5                                 ; 下面根据 bootpack 的 ELF 头信息进行段重定位，然后跳转执行
   127 0000C2B5                                 ; -----------------------------------------------------------
   128 0000C2B5                                 
   129 0000C2B5                                 ; -----------------------------------------------------------
   130 0000C2B5                                 ; 处理 bootpack 的重定位信息（根据 ELF 程序头进行内存复制）
   131 0000C2B5                                 ; -----------------------------------------------------------
   132 0000C2B5 66 BB 00280000                          MOV     EBX, BOTPAK          ; EBX = bootpack 基址（0x280000）
   133 0000C2BB 67 66 8B 4B 10                          MOV     ECX, [EBX+16]        ; ECX = ELF 头中 .p_filesz 字段（段的文件大小）
   134 0000C2C0 66 83 C1 03                             ADD     ECX, 3               ; ECX += 3（向上取整对齐到 4 字节边界）
   135 0000C2C4 66 C1 E9 02                             SHR     ECX, 2               ; ECX /= 4（将字节数转换为双字数）
   136 0000C2C8 74 10                                   JZ      skip                 ; 如果大小为 0，跳过复制（无需重定位）
   137 0000C2CA 67 66 8B 73 14                          MOV     ESI, [EBX+20]        ; 源地址 = bootpack 基址 + .p_offset 字段
   138 0000C2CF 66 01 DE                                ADD     ESI, EBX
   139 0000C2D2 67 66 8B 7B 0C                          MOV     EDI, [EBX+12]        ; 目标地址 = .p_vaddr 字段（虚拟地址）
   140 0000C2D7 E8 0014                                 CALL    memcpy               ; 执行段复制
   141 0000C2DA                                 skip:
   142 0000C2DA                                 ; -----------------------------------------------------------
   143 0000C2DA                                 ; 设置栈指针，然后通过远跳转将控制权交给 bootpack 入口代码
   144 0000C2DA                                 ; -----------------------------------------------------------
   145 0000C2DA 67 66 8B 63 0C                          MOV     ESP, [EBX+12]        ; 从 ELF 头中读取入口所需的初始栈地址（.p_vaddr）
   146 0000C2DF 66 EA 0000001B 0010                     JMP     DWORD 2*8:0x0000001b ; 远跳转到代码段（选择子 2*8）+ 偏移 0x1B
   147 0000C2E7                                                                       ; 选择子 2*8 指向 GDT 中第 2 项（可执行段，32bit）
   148 0000C2E7                                 
   149 0000C2E7                                 ; ============================================================
   150 0000C2E7                                 ; 子程序：等待键盘控制器输出缓冲区空闲
   151 0000C2E7                                 ; ============================================================
   152 0000C2E7                                 waitkbdout:
   153 0000C2E7 E4 64                                   IN      AL, 0x64            ; 读取键盘控制器状态端口 0x64
   154 0000C2E9 24 02                                   AND     AL, 0x02            ; 测试 bit1（输入缓冲区满标志）
   155 0000C2EB 75 FA                                   JNZ     waitkbdout          ; 若不为 0，表示缓冲区仍忙，继续等待
   156 0000C2ED C3                                      RET
   157 0000C2EE                                 
   158 0000C2EE                                 ; ============================================================
   159 0000C2EE                                 ; 子程序：内存复制（以双字为单位，一次复制 4 字节）
   160 0000C2EE                                 ; 参数：ESI = 源地址，EDI = 目标地址，ECX = 双字数
   161 0000C2EE                                 ; 注意：此实现未考虑地址前缀，在使用字符串指令后可用更高效的写法
   162 0000C2EE                                 ; ============================================================
   163 0000C2EE                                 memcpy:
   164 0000C2EE 67 66 8B 06                             MOV     EAX, [ESI]          ; 从源地址读取一个双字（4 字节）
   165 0000C2F2 66 83 C6 04                             ADD     ESI, 4              ; 源指针前移 4 字节
   166 0000C2F6 67 66 89 07                             MOV     [EDI], EAX          ; 写入到目标地址
   167 0000C2FA 66 83 C7 04                             ADD     EDI, 4              ; 目标指针前移 4 字节
   168 0000C2FE 66 83 E9 01                             SUB     ECX, 1              ; 计数器减 1
   169 0000C302 75 EA                                   JNZ     memcpy              ; 若未复制完（ECX != 0），继续循环
   170 0000C304 C3                                      RET
   171 0000C305                                 
   172 0000C305                                 ; ============================================================
   173 0000C305                                 ; 全局描述符表（GDT）
   174 0000C305                                 ; ============================================================
   175 0000C305 00 00 00 00 00 00 00 00 00 00           ALIGNB  16                  ; 16 字节对齐
       0000C30F 00 
   176 0000C310                                 GDT0:
   177 0000C310 00 00 00 00 00 00 00 00                 RESB    8                   ; 第 0 项：空描述符（CPU 要求必须存在）
   178 0000C318                                         ; 第 1 项：数据段描述符（可读写，32 位）
   179 0000C318                                         ; 基址=0，界限=0xFFFFF，DPL=0，G=1（4KB 粒度）→ 覆盖整个 4GB 地址空间
   180 0000C318 FFFF 0000 9200 00CF                     DW      0xffff, 0x0000, 0x9200, 0x00cf
   181 0000C320                                         ; 第 2 项：代码段描述符（可执行，32 位，供 bootpack 使用）
   182 0000C320                                         ; 基址=0，界限=0xFFFFF，DPL=0，G=1（4KB 粒度）
   183 0000C320 FFFF 0000 9A28 0047                     DW      0xffff, 0x0000, 0x9a28, 0x0047
   184 0000C328                                 
   185 0000C328 0000                                    DW      0                   ; 结束标记（GDT 边界用）
   186 0000C32A                                 GDTR0:
   187 0000C32A 0017                                    DW      8*3-1               ; GDT 界限 = 表总字节数 - 1（3 个描述符 × 8 - 1）
   188 0000C32C 0000C310                                DD      GDT0                ; GDT 基址（线性地址）
   189 0000C330                                 
   190 0000C330                                         ALIGNB  16
   191 0000C330                                 bootpack:                           ; bootpack 二进制数据（由链接器附加在此标签之后）