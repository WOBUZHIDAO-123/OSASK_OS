     1 00000000                                 ; naskfunc
     2 00000000                                 ; TAB=4
     3 00000000                                 ;=====================================================================
     4 00000000                                 ; 本文件用于向 bootPack.c 提供底层硬件操作函数
     5 00000000                                 ; bootPack.c 中调用的 io_xxx 系列函数都在这里用汇编实现
     6 00000000                                 ; 因为 C 语言无法直接执行 IN/OUT/CLI/STI/HLT 等底层指令
     7 00000000                                 ;=====================================================================
     8 00000000                                 
     9 00000000                                 
    10 00000000                                 [FORMAT "WCOFF"]    ; 输出格式: Windows COFF 对象文件
    11 00000000                                                     ; bootPack.c 编译后的 .obj 文件会与此文件链接
    12 00000000                                 
    13 00000000                                 [BITS 32]           ; 生成 32 位保护模式代码
    14 00000000                                                     ; 我们的操作系统运行在 32 位保护模式下
    15 00000000                                 
    16 00000000                                 [INSTRSET "i486p"]  ; 允许使用 i486 及以上的指令集
    17 00000000                                 
    18 00000000                                 [FILE "naskfunc.nas"]
    19 00000000                                 
    20 00000000                                 ;--------------------------------------------------------------------------
    21 00000000                                 ; GLOBAL 声明 —— 将这些符号导出，供 C 语言链接使用
    22 00000000                                 ; C 语言调用时，会自动在函数名前加下划线，所以这里用 _io_hlt 等名称
    23 00000000                                 ;--------------------------------------------------------------------------
    24 00000000                                     GLOBAL _io_hlt              ; void io_hlt(void);
    25 00000000                                     GLOBAL _io_cli, _io_sti, _io_stihlt   ; 中断控制相关
    26 00000000                                     GLOBAL _io_in8, _io_in16, _io_in32    ; I/O 端口读取（8/16/32 位）
    27 00000000                                     GLOBAL _io_out8, _io_out16, _io_out32 ; I/O 端口写入（8/16/32 位）
    28 00000000                                     GLOBAL _io_load_eflags, _io_store_eflags  ; EFLAGS 寄存器操作
    29 00000000                                     GLOBAL _load_gdtr, _load_idtr             ; GDT/IDT 表寄存器加载（GDTR/IDTR）
    30 00000000                                     GLOBAL _asm_inthandler21, _asm_inthandler27, _asm_inthandler2c  ; 中断处理入口（键盘/伪中断/鼠标）
    31 00000000                                 
    32 00000000                                 ; 外部函数引用 —— 由 C 语言 int.c 导出的中断处理函数
    33 00000000                                 ; 汇编中 CALL 时必须先 EXTERN 声明，链接器才能找到对应的 C 符号
    34 00000000                                     EXTERN _inthandler21, _inthandler27, _inthandler2c
    35 00000000                                 
    36 00000000                                 
    37                                          [SECTION .text]
    38 00000000                                 
    39 00000000                                 ;==========================================================================
    40 00000000                                 ; 函数: io_hlt(void)
    41 00000000                                 ; 功能: 执行 HLT 指令，让 CPU 进入待机状态，直到下次中断发生才唤醒
    42 00000000                                 ; 参数: 无
    43 00000000                                 ; 返回: 无
    44 00000000                                 ; 寄存器: 不使用任何寄存器传递参数或返回值
    45 00000000                                 ;==========================================================================
    46 00000000                                 _io_hlt:
    47 00000000 F4                                  HLT                 ; Halt —— CPU 暂停执行，进入低功耗待机模式
    48 00000001                                                         ; 外部中断或异常到来时恢复执行下一条指令
    49 00000001 C3                                  RET                 ; 返回到 C 语言调用者
    50 00000002                                                         ; 返回值在栈上，由调用者清理
    51 00000002                                 
    52 00000002                                 
    53 00000002                                 ;==========================================================================
    54 00000002                                 ; 函数: io_cli(void)
    55 00000002                                 ; 功能: 执行 CLI (Clear Interrupt) 指令，屏蔽 CPU 对 PIC 中断信号的响应
    56 00000002                                 ;       此后 CPU 将忽略外部设备的中断请求，直到执行 STI 重新恢复
    57 00000002                                 ; 参数: 无
    58 00000002                                 ; 返回: 无
    59 00000002                                 ; 寄存器: 不使用
    60 00000002                                 ;==========================================================================
    61 00000002                                 _io_cli:
    62 00000002 FA                                  CLI                 ; Clear Interrupt —— 清除 IF 标志位（EFLAGS 第 9 位）
    63 00000003                                                         ; IF=0 时，CPU 不再响应可屏蔽中断（INTR 引脚来的中断）
    64 00000003 C3                                  RET
    65 00000004                                 
    66 00000004                                 
    67 00000004                                 ;==========================================================================
    68 00000004                                 ; 函数: io_sti(void)
    69 00000004                                 ; 功能: 执行 STI (Set Interrupt) 指令，恢复 CPU 对 PIC 中断信号的响应
    70 00000004                                 ;       重新允许 CPU 接收外部设备的中断请求
    71 00000004                                 ; 参数: 无
    72 00000004                                 ; 返回: 无
    73 00000004                                 ; 寄存器: 不使用
    74 00000004                                 ;==========================================================================
    75 00000004                                 _io_sti:
    76 00000004 FB                                  STI                 ; Set Interrupt —— 设置 IF 标志位（EFLAGS 第 9 位）
    77 00000005                                                         ; IF=1 时，CPU 恢复响应可屏蔽中断
    78 00000005 C3                                  RET
    79 00000006                                 
    80 00000006                                 
    81 00000006                                 ;==========================================================================
    82 00000006                                 ; 函数: io_stihlt(void)
    83 00000006                                 ; 功能: 先恢复对 PIC 中断信号的响应，再立即执行 HLT 待机
    84 00000006                                 ;       典型用途：操作系统空闲时调用，既能响应中断，又能省电
    85 00000006                                 ; 参数: 无
    86 00000006                                 ; 返回: 无
    87 00000006                                 ; 寄存器: 不使用
    88 00000006                                 ;==========================================================================
    89 00000006                                 _io_stihlt:
    90 00000006 FB                                  STI                 ; 先恢复对 PIC 中断信号的响应 —— 确保 HLT 后中断能唤醒 CPU
    91 00000007 F4                                  HLT                 ; 再待机 —— 等待下一次中断到来
    92 00000008 C3                                  RET
    93 00000009                                 
    94 00000009                                 
    95 00000009                                 ;==========================================================================
    96 00000009                                 ; 函数: io_in8(int port) port就是设备端口号
    97 00000009                                 ; 功能: 从指定的 I/O 端口读取 8 位（1 字节）数据
    98 00000009                                 ; 参数: port —— I/O 端口地址（0x0000~0xFFFF），通过栈传递
    99 00000009                                 ; 返回: 读取到的 8 位数据，零扩展到 32 位后返回
   100 00000009                                 ; 寄存器:
   101 00000009                                 ;   EDX ← port（I/O 指令 IN 要求端口号必须放在 DX 寄存器中）
   102 00000009                                 ;   EAX ← 返回值（函数的返回值固定放在 EAX 中）
   103 00000009                                 ;   AL  ← IN 指令从端口读到的 8 位数据
   104 00000009                                 ; 栈布局:
   105 00000009                                 ;   [ESP+0] = 返回地址（CALL 指令压入）
   106 00000009                                 ;   [ESP+4] = 第 1 个参数 port
   107 00000009                                 ;==========================================================================
   108 00000009                                 _io_in8:
   109 00000009 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port（第 1 个参数，在返回地址上方 4 字节）
   110 0000000D                                                             ; I/O 指令 IN/OUT 必须用 DX 或 EDX 指定端口号
   111 0000000D B8 00000000                         MOV     EAX,0           ; EAX 高位置 0，保证返回值干净（高 24 位 = 0）
   112 00000012 EC                                  IN      AL,DX           ; AL = 从端口 DX 读入的 8 位数据
   113 00000013                                                             ; IN AL,DX 从 8 位端口读 8 位 → AL
   114 00000013 C3                                  RET                     ; 返回 EAX（低 8 位 AL 是有效数据）
   115 00000014                                 
   116 00000014                                 
   117 00000014                                 ;==========================================================================
   118 00000014                                 ; 函数: io_in16(int port)
   119 00000014                                 ; 功能: 从指定的 I/O 端口读取 16 位（2 字节）数据
   120 00000014                                 ; 参数: port —— I/O 端口地址
   121 00000014                                 ; 返回: 读取到的 16 位数据，零扩展到 32 位后返回
   122 00000014                                 ; 寄存器:
   123 00000014                                 ;   EDX ← port
   124 00000014                                 ;   EAX ← 返回值
   125 00000014                                 ;   AX  ← IN 指令从端口读到的 16 位数据
   126 00000014                                 ;==========================================================================
   127 00000014                                 _io_in16:
   128 00000014 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   129 00000018 B8 00000000                         MOV     EAX,0           ; EAX 高 16 位置 0
   130 0000001D 66 ED                               IN      AX,DX           ; AX = 从端口 DX 读入的 16 位数据
   131 0000001F                                                             ; IN AX,DX 从 16 位端口读 16 位 → AX
   132 0000001F C3                                  RET
   133 00000020                                 
   134 00000020                                 
   135 00000020                                 ;==========================================================================
   136 00000020                                 ; 函数: io_in32(int port)
   137 00000020                                 ; 功能: 从指定的 I/O 端口读取 32 位（4 字节）数据
   138 00000020                                 ; 参数: port —— I/O 端口地址
   139 00000020                                 ; 返回: 读取到的 32 位数据
   140 00000020                                 ; 寄存器:
   141 00000020                                 ;   EDX ← port
   142 00000020                                 ;   EAX ← IN 指令读到的 32 位数据（同时也是返回值）
   143 00000020                                 ;==========================================================================
   144 00000020                                 _io_in32:
   145 00000020 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   146 00000024 ED                                  IN      EAX,DX          ; EAX = 从端口 DX 读入的 32 位数据
   147 00000025                                                             ; IN EAX,DX 从 32 位端口读 32 位 → EAX
   148 00000025 C3                                  RET                     ; EAX 直接作为返回值返回，无需额外处理
   149 00000026                                 
   150 00000026                                 
   151 00000026                                 ;==========================================================================
   152 00000026                                 ; 函数: io_out8(int port, int data)
   153 00000026                                 ; 功能: 向指定的 I/O 端口写入 8 位（1 字节）数据
   154 00000026                                 ; 参数: port —— I/O 端口地址（第 1 个参数）
   155 00000026                                 ;       data —— 要写入的 8 位数据（第 2 个参数）
   156 00000026                                 ; 返回: 无
   157 00000026                                 ; 寄存器:
   158 00000026                                 ;   EDX ← port
   159 00000026                                 ;   AL  ← data（OUT 指令将 AL 的内容写到 DX 指定的端口）
   160 00000026                                 ; 栈布局:
   161 00000026                                 ;   [ESP+0] = 返回地址
   162 00000026                                 ;   [ESP+4] = 第 1 个参数 port
   163 00000026                                 ;   [ESP+8] = 第 2 个参数 data
   164 00000026                                 ;==========================================================================
   165 00000026                                 _io_out8:
   166 00000026 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   167 0000002A 8A 44 24 08                         MOV     AL,[ESP+8]      ; AL  = data（只取低 8 位，高 24 位忽略）
   168 0000002E EE                                  OUT     DX,AL           ; 将 AL 的 8 位数据写入端口 DX
   169 0000002F                                                             ; OUT DX,AL 是标准的 8 位 I/O 写入指令
   170 0000002F C3                                  RET
   171 00000030                                 
   172 00000030                                 
   173 00000030                                 ;==========================================================================
   174 00000030                                 ; 函数: io_out16(int port, int data)
   175 00000030                                 ; 功能: 向指定的 I/O 端口写入 16 位（2 字节）数据
   176 00000030                                 ; 参数: port —— I/O 端口地址
   177 00000030                                 ;       data —— 要写入的 16 位数据
   178 00000030                                 ; 返回: 无
   179 00000030                                 ; 寄存器:
   180 00000030                                 ;   EDX ← port
   181 00000030                                 ;   EAX ← data（仅低 16 位 AX 有效）
   182 00000030                                 ;==========================================================================
   183 00000030                                 _io_out16:
   184 00000030 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   185 00000034 8B 44 24 08                         MOV     EAX,[ESP+8]     ; EAX = data（OUT 指令只使用 AX 部分）
   186 00000038 66 EF                               OUT     DX,AX           ; 将 AX 的 16 位数据写入端口 DX
   187 0000003A C3                                  RET
   188 0000003B                                 
   189 0000003B                                 
   190 0000003B                                 ;==========================================================================
   191 0000003B                                 ; 函数: io_out32(int port, int data)
   192 0000003B                                 ; 功能: 向指定的 I/O 端口写入 32 位（4 字节）数据
   193 0000003B                                 ; 参数: port —— I/O 端口地址
   194 0000003B                                 ;       data —— 要写入的 32 位数据
   195 0000003B                                 ; 返回: 无
   196 0000003B                                 ; 寄存器:
   197 0000003B                                 ;   EDX ← port
   198 0000003B                                 ;   EAX ← data（完整的 32 位数据）
   199 0000003B                                 ;==========================================================================
   200 0000003B                                 _io_out32:
   201 0000003B 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   202 0000003F 8B 44 24 08                         MOV     EAX,[ESP+8]     ; EAX = data
   203 00000043 EF                                  OUT     DX,EAX          ; 将 EAX 的 32 位数据写入端口 DX
   204 00000044 C3                                  RET
   205 00000045                                 
   206 00000045                                 
   207 00000045                                 ;==========================================================================
   208 00000045                                 ; 函数: io_load_eflags(void)
   209 00000045                                 ; 功能: 读取当前 CPU 的 EFLAGS 寄存器并返回
   210 00000045                                 ;       常用于在修改关键标志前保存当前状态
   211 00000045                                 ; 参数: 无
   212 00000045                                 ; 返回: EFLAGS 寄存器的 32 位值
   213 00000045                                 ; 寄存器:
   214 00000045                                 ;   EAX ← EFLAGS（通过栈间接传递：PUSHFD → POP EAX）
   215 00000045                                 ; 注意:
   216 00000045                                 ;   EFLAGS 中每位代表一个标志，例如：
   217 00000045                                 ;     Bit 0  (CF)  = 进位标志
   218 00000045                                 ;     Bit 6  (ZF)  = 零标志
   219 00000045                                 ;     Bit 9  (IF)  = 中断许可标志（我们最常用的）
   220 00000045                                 ;     Bit 7  (SF)  = 符号标志
   221 00000045                                 ;==========================================================================
   222 00000045                                 _io_load_eflags:
   223 00000045 9C                                  PUSHFD              ; 将 EFLAGS 寄存器的值压入栈
   224 00000046                                                         ; PUSHFD = Push EFLAGS Double-word (32位)
   225 00000046 58                                  POP     EAX         ; 弹出到 EAX，作为函数返回值
   226 00000047                                                         ; 相当于 EFLAGS → 栈 → EAX
   227 00000047 C3                                  RET
   228 00000048                                 
   229 00000048                                 
   230 00000048                                 ;==========================================================================
   231 00000048                                 ; 函数: io_store_eflags(int eflags)
   232 00000048                                 ; 功能: 将指定的值写入 EFLAGS 寄存器，恢复之前保存的 CPU 状态
   233 00000048                                 ;       一般与 io_load_eflags 配对使用
   234 00000048                                 ; 参数: eflags —— 要写入 EFLAGS 寄存器的 32 位值
   235 00000048                                 ; 返回: 无
   236 00000048                                 ; 寄存器:
   237 00000048                                 ;   EAX ← eflags（准备压栈）
   238 00000048                                 ;   栈 → EFLAGS（通过 POPFD 实现）
   239 00000048                                 ; 流程:
   240 00000048                                 ;   参数 eflags → EAX → 压栈 PUSH → 弹入 EFLAGS (POPFD)
   241 00000048                                 ;==========================================================================
   242 00000048                                 _io_store_eflags:
   243 00000048 8B 44 24 04                         MOV     EAX,[ESP+4]     ; EAX = eflags（第 1 个参数）
   244 0000004C 50                                  PUSH    EAX             ; 将 eflags 压入栈
   245 0000004D 9D                                  POPFD                   ; 从栈弹出到 EFLAGS 寄存器
   246 0000004E                                                             ; POPFD = Pop stack to EFLAGS Double-word
   247 0000004E                                                             ; 完成 EFLAGS 的恢复
   248 0000004E C3                                  RET                     ; 在执行RET时，EAX的值就是返回值
   249 0000004F                                 
   250 0000004F                                 
   251 0000004F                                 ;==========================================================================
   252 0000004F                                 ; 函数: load_gdtr(int limit, int addr)
   253 0000004F                                 ; 功能: 执行 LGDT 指令，加载全局描述符表寄存器 GDTR
   254 0000004F                                 ;       告诉 CPU 全局描述符表 GDT 在哪（地址）以及多大（界限）
   255 0000004F                                 ; 参数:
   256 0000004F                                 ;   limit —— GDT 界限值 = 总字节数 - 1（第 1 个参数，16 位）
   257 0000004F                                 ;   addr  —— GDT 基地址（第 2 个参数，32 位）
   258 0000004F                                 ; 返回: 无
   259 0000004F                                 ; 栈布局:
   260 0000004F                                 ;   [ESP+0] = 返回地址
   261 0000004F                                 ;   [ESP+4] = limit
   262 0000004F                                 ;   [ESP+8] = addr
   263 0000004F                                 ; 实现技巧:
   264 0000004F                                 ;   不显式构造 6 字节伪描述符，而是利用栈上已有的参数位置：
   265 0000004F                                 ;   ① 将 limit 写入 [ESP+6]
   266 0000004F                                 ;   ② [ESP+8] 处已经是 addr（第 2 个参数）
   267 0000004F                                 ;   ③ LGDT [ESP+6] 从栈上读取 6 字节 → [ESP+6~11]
   268 0000004F                                 ;      ┌────────┬────────┐
   269 0000004F                                 ;      │ limit  │  addr  │
   270 0000004F                                 ;      │ 2 bytes│ 4 bytes│
   271 0000004F                                 ;      └────────┴────────┘
   272 0000004F                                 ;      ESP+6   ESP+8    ESP+12
   273 0000004F                                 ;==========================================================================
   274 0000004F                                 _load_gdtr:
   275 0000004F 66 8B 44 24 04                          MOV		AX,[ESP+4]		; AX = limit（第 1 个参数）
   276 00000054 66 89 44 24 06                          MOV		[ESP+6],AX		; 将 limit 写入伪描述符低 2 字节位置
   277 00000059 0F 01 54 24 06                          LGDT	[ESP+6]			; 从栈加载 6 字节伪描述符到 GDTR
   278 0000005E C3                                      RET						; 返回（无需清理栈，未使用 PUSH）
   279 0000005F                                 
   280 0000005F                                 
   281 0000005F                                 ;==========================================================================
   282 0000005F                                 ; 函数: load_idtr(int limit, int addr)
   283 0000005F                                 ; 功能: 执行 LIDT 指令，加载中断描述符表寄存器 IDTR
   284 0000005F                                 ;       告诉 CPU 中断描述符表 IDT 在哪（地址）以及多大（界限）
   285 0000005F                                 ; 参数与 load_gdtr 完全一致：
   286 0000005F                                 ;   limit —— IDT 界限值 = 总字节数 - 1（第 1 个参数）
   287 0000005F                                 ;   addr  —— IDT 基地址（第 2 个参数）
   288 0000005F                                 ; 返回: 无
   289 0000005F                                 ;==========================================================================
   290 0000005F                                 _load_idtr:
   291 0000005F 66 8B 44 24 04                          MOV		AX,[ESP+4]		; AX = limit
   292 00000064 66 89 44 24 06                          MOV		[ESP+6],AX		; 写入伪描述符低 2 字节
   293 00000069 0F 01 5C 24 06                          LIDT	[ESP+6]			; 从栈加载 6 字节伪描述符到 IDTR
   294 0000006E C3                                      RET
   295 0000006F                                 
   296 0000006F                                 
   297 0000006F                                 ; ============================================================
   298 0000006F                                 ; 键盘中断处理入口（IRQ1 → IDT 0x21）
   299 0000006F                                 ; CPU 收到键盘中断时通过 IDT[0x21] 的门描述符跳转到此
   300 0000006F                                 ; 流程：保存现场 → 传栈指针给 C → 统一段寄存器 → CALL C 函数 → 恢复 → IRETD
   301 0000006F                                 ; ============================================================
   302 0000006F                                 _asm_inthandler21:
   303 0000006F 06                                  PUSH    ES
   304 00000070 1E                                  PUSH    DS
   305 00000071 60                                  PUSHAD
   306 00000072 89 E0                               MOV     EAX,ESP
   307 00000074 50                                  PUSH    EAX
   308 00000075 66 8C D0                            MOV     AX,SS
   309 00000078 8E D8                               MOV     DS,AX
   310 0000007A 8E C0                               MOV     ES,AX
   311 0000007C E8 [00000000]                       CALL    _inthandler21
   312 00000081 58                                  POP     EAX
   313 00000082 61                                  POPAD
   314 00000083 1F                                  POP     DS
   315 00000084 07                                  POP     ES
   316 00000085 CF                                  IRETD
   317 00000086                                 
   318 00000086                                 
   319 00000086                                 ; ============================================================
   320 00000086                                 ; PIC1 伪中断处理入口（IRQ7 → IDT 0x27）
   321 00000086                                 ; 主 PIC 通过 IRQ2 接收从 PIC 的中继。当从片发出中断但具体 IRQ 被屏蔽时，
   322 00000086                                 ; 主 PIC 发 IRQ7 伪中断兜底，必须注册避免系统死锁。
   323 00000086                                 ; 结构与 _asm_inthandler21 完全相同
   324 00000086                                 ; ============================================================
   325 00000086                                 _asm_inthandler27:
   326 00000086 06                                  PUSH    ES
   327 00000087 1E                                  PUSH    DS
   328 00000088 60                                  PUSHAD
   329 00000089 89 E0                               MOV     EAX,ESP
   330 0000008B 50                                  PUSH    EAX
   331 0000008C 66 8C D0                            MOV     AX,SS
   332 0000008F 8E D8                               MOV     DS,AX
   333 00000091 8E C0                               MOV     ES,AX
   334 00000093 E8 [00000000]                       CALL    _inthandler27
   335 00000098 58                                  POP     EAX
   336 00000099 61                                  POPAD
   337 0000009A 1F                                  POP     DS
   338 0000009B 07                                  POP     ES
   339 0000009C CF                                  IRETD
   340 0000009D                                 
   341 0000009D                                 
   342 0000009D                                 ; ============================================================
   343 0000009D                                 ; 鼠标中断处理入口（IRQ12 → IDT 0x2C）
   344 0000009D                                 ; 鼠标使用 PS/2 通道，从 PIC 管理 IRQ8~IRQ15，IRQ12 映射到 IDT 0x2C。
   345 0000009D                                 ; 结构与 _asm_inthandler21 完全相同
   346 0000009D                                 ; ============================================================
   347 0000009D                                 _asm_inthandler2c:
   348 0000009D 06                                  PUSH    ES
   349 0000009E 1E                                  PUSH    DS
