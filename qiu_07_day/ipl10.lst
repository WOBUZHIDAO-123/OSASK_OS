     1 00000000                                 ; hello-os
     2 00000000                                 ; TAB=4
     3 00000000                                 
     4  = 0000000A                              		CYLS	EQU		10				; 声明CYLS=10
     5 00000000                                 
     6                                          		ORG		0x7c00			; 指明程序装载地址
     7 00007C00                                 
     8 00007C00                                 ; 标准FAT12格式软盘专用的代码
     9 00007C00                                 ; Stand FAT12 format floppy code
    10 00007C00 EB 3C                           		JMP		entry
    11 00007C02 90                              		NOP					; 这两个字节是标准的跳转填充
    12 00007C03 48 45 4C 4C 4F 49 50 4C         		DB		"HELLOIPL"		; 启动扇区名称（8字节）(OEM Name, 8 bytes)
    13 00007C0B 0200                            		DW		512				; 每个扇区（sector）大小（必须512字节）(Bytes per Sector)
    14 00007C0D 01                              		DB		1				; 簇（cluster）大小（必须为1个扇区）(Sectors per Cluster)
    15 00007C0E 0001                            		DW		1				; FAT起始位置（一般为第一个扇区）(Reserved Sectors)
    16 00007C10 02                              		DB		2				; FAT个数（必须为2）(Number of FATS)
    17 00007C11 00E0                            		DW		224				; 根目录大小（一般为224项）(Root Entries)
    18 00007C13 0B40                            		DW		2880			; 该磁盘大小（必须为2880扇区1440*1024/512）(Total Sectors)
    19 00007C15 F0                              		DB		0xf0			; 磁盘类型（必须为0xf0）(Media Descriptor)
    20 00007C16 0009                            		DW		9				; FAT的长度（必须9扇区）(Sectors per FAT)
    21 00007C18 0012                            		DW		18				; 一个磁道（track）有几个扇区（必须为18）(Sectors per Track)
    22 00007C1A 0002                            		DW		2				; 磁头数（必须2）(Number of Heads)
    23 00007C1C 00000000                        		DD		0				; 不使用分区，必须是0(Hidden Sectors)
    24 00007C20 00000B40                        		DD		2880			; 重写一次磁盘大小(Large Sectors)
    25 00007C24                                 
    26 00007C24                                 		; 扩展BPB部分 (Extended BPB)
    27 00007C24 00                              		DB		0x00			; 驱动器号 (Drive Number)
    28 00007C25 00                              		DB		0x00			; 保留 (Reserved)
    29 00007C26 29                              		DB		0x29			; 扩展引导签名 (Extended Boot Signature)
    30 00007C27 12345678                        		DD		0x12345678		; 卷序列号 (Volume Serial Number)
    31 00007C2B 48 45 4C 4C 4F 2D 4F 53 20 20   		DB		"HELLO-OS   "	; 磁盘的名称（必须为11字节，不足填空格）(Volume Label, 11 bytes)
       00007C35 20 
    32 00007C36 46 41 54 31 32 20 20 20         		DB		"FAT12   "		; 磁盘格式名称（必须为8字节，不足填空格）(File System Type, 8 bytes)
    33 00007C3E                                 		; 注意：这里没有 RESB 18 了！
    34 00007C3E                                 
    35 00007C3E                                 ; 程序主体
    36 00007C3E                                 entry:
    37 00007C3E B8 0000                         		MOV		AX,0			; 初始化寄存器
    38 00007C41 8E D0                           		MOV		SS,AX
    39 00007C43 BC 7C00                         		MOV		SP,0x7c00
    40 00007C46 8E D8                           		MOV		DS,AX
    41 00007C48 8E C0                           		MOV		ES,AX
    42 00007C4A                                 
    43 00007C4A                                 ;新增内容
    44 00007C4A                                 error:
    45 00007C4A BE 7CB7                         		MOV		SI,msg
    46 00007C4D                                 
    47 00007C4D                                 	;读取扇区
    48 00007C4D B8 0820                         		MOV 	AX,0x0820
    49 00007C50 8E C0                           		MOV 	ES,AX
    50 00007C52 B5 00                           		MOV 	CH,0			; 柱面0
    51 00007C54 B6 00                           		MOV 	DH,0			; 磁头0
    52 00007C56 B1 02                           		MOV 	CL,2			; 扇区2
    53 00007C58                                 
    54 00007C58                                 readLoop:
    55 00007C58 BE 0000                         		MOV 	SI,0			; 记录失败次数的寄存器
    56 00007C5B                                 
    57 00007C5B                                 retry:
    58 00007C5B B4 02                           		MOV 	AH,0x02		; AH=0x02 ： 读盘
    59 00007C5D B0 01                           		MOV 	AL,1			; 1个扇区
    60 00007C5F BB 0000                         		MOV 	BX,0
    61 00007C62 B2 00                           		MOV 	DL,0x00		; A驱动器
    62 00007C64 CD 13                           		INT		0x13			; 调用磁盘BIOS提供的关于磁盘的函数，成功则进位标记CF返回0
    63 00007C66 73 10                           		JNC		next			; JNC条件跳转，当进位标记CF为0时跳转
    64 00007C68 83 C6 01                        		ADD		SI,1			; SI加1
    65 00007C6B 83 FE 05                        		CMP		SI,5			; 比较SI和5
    66 00007C6E 73 DA                           		JAE		error			; JAE条件跳转，对比结果大于等于时跳转
    67 00007C70 B4 00                           		MOV 	AH,0x00		
    68 00007C72 B2 00                           		MOV 	DL,0x00		; A驱动器
    69 00007C74 CD 13                           		INT		0x13			; 重置驱动器
    70 00007C76 EB E3                           		JMP		retry
    71 00007C78                                 
    72 00007C78                                 next:
    73 00007C78 8C C0                           		MOV 	AX,ES
    74 00007C7A 05 0020                         		ADD		AX,0x0020
    75 00007C7D 8E C0                           		MOV		ES,AX
    76 00007C7F 80 C1 01                        		ADD		CL,1
    77 00007C82 80 F9 12                        		CMP		CL,18			; 比较CL和18
    78 00007C85 76 D1                           		JBE		readLoop		; JBE条件跳转，对比结果小于等于时跳转
    79 00007C87 B1 01                           		MOV		CL,1
    80 00007C89 80 C6 01                        		ADD		DH,1
    81 00007C8C 80 FE 02                        		CMP		DH,2
    82 00007C8F 72 C7                           		JB		readLoop		; JB条件跳转，对比结果小于时跳转	
    83 00007C91 B6 00                           		MOV		DH,0
    84 00007C93 80 C5 01                        		ADD		CH,1
    85 00007C96 80 FD 0A                        		CMP		CH,CYLS
    86 00007C99 72 BD                           		JB		readLoop		
    87 00007C9B                                 ; 读取完毕，跳转到haribote.sys执行！
    88 00007C9B 88 2E 0FF0                      		MOV		[0x0ff0],CH		; 记录读取进度
    89 00007C9F E9 455E                         		JMP		0xc200			; 关键！成功读取后跳转到0xc200执行内核
    90 00007CA2                                 
    91 00007CA2                                 ;新增内容结尾
    92 00007CA2                                 
    93 00007CA2                                 putloop:
    94 00007CA2 8A 04                           		MOV		AL,[SI]
    95 00007CA4 83 C6 01                        		ADD		SI,1			; 给SI加1
    96 00007CA7 3C 00                           		CMP		AL,0
    97 00007CA9 74 09                           		JE		fin
    98 00007CAB B4 0E                           		MOV		AH,0x0e			; 显示一个文字
    99 00007CAD BB 000F                         		MOV		BX,15			; 指定字符颜色
   100 00007CB0 CD 10                           		INT		0x10			; 调用显卡BIOS
   101 00007CB2 EB EE                           		JMP		putloop
   102 00007CB4                                 fin:
   103 00007CB4 F4                              		HLT						; 让CPU停止，等待指令
   104 00007CB5 EB FD                           		JMP		fin				; 无限循环
   105 00007CB7                                 
   106 00007CB7                                 msg:
   107 00007CB7 0A 0A                           		DB		0x0a, 0x0a		; 换行两次
   108 00007CB9 65 72 72 6F 72                  		DB		"error"
   109 00007CBE 0A                              		DB		0x0a			; 换行
   110 00007CBF 00                              		DB		0
   111 00007CC0                                 
   112 00007CC0                                 ;结尾填充
   113 00007CC0 00 00 00 00 00 00 00 00 00 00   		RESB	0x7dfe-$		; 填写0x00直到0x001fe
       00007CCA 00 00 00 00 00 00 00 00 00 00 
       00007CD4 00 00 00 00 00 00 00 00 00 00 
       00007CDE 00 00 00 00 00 00 00 00 00 00 
       00007CE8 00 00 00 00 00 00 00 00 00 00 
       00007CF2 00 00 00 00 00 00 00 00 00 00 
       00007CFC 00 00 00 00 00 00 00 00 00 00 
       00007D06 00 00 00 00 00 00 00 00 00 00 
       00007D10 00 00 00 00 00 00 00 00 00 00 
