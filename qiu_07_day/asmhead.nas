; haribote-os boot asm
; TAB=4

; ============================================================
; 常量定义
; ============================================================
BOTPAK  EQU     0x00280000      ; bootpack 的加载目标地址（内存高端，避开 BIOS/显存区域）
DSKCAC  EQU     0x00100000      ; 磁盘缓存存放位置（将整个磁盘映像复制到这里）
DSKCAC0 EQU     0x00008000      ; 磁盘缓存存放位置（实模式阶段，先暂存到低端内存）

; ============================================================
; BOOT_INFO 相关定义（由引导扇区 IPL 写入，供内核读取）
; ============================================================
CYLS    EQU     0x0ff0          ; IPL 探测到的柱面数（Cylinders），引导扇区设置
LEDS    EQU     0x0ff1          ; 键盘 LED 状态（Num Lock / Caps Lock 等）
VMODE   EQU     0x0ff2          ; 显示模式信息（多少位色彩等）
SCRNX   EQU     0x0ff4          ; 屏幕分辨率 X（水平像素数）
SCRNY   EQU     0x0ff6          ; 屏幕分辨率 Y（垂直像素数）
VRAM    EQU     0x0ff8          ; 显存（VRAM）起始地址

; -----------------------------------------------------------
; 代码入口：本程序由 IPL 加载到 0xc200 处并跳转至此执行
; -----------------------------------------------------------
        ORG     0xc200          ; 指定程序加载地址为 0xc200

; -----------------------------------------------------------
; 设置显示模式（VGA 图形模式 320×200×8bit 彩色）
; -----------------------------------------------------------
        MOV     AL, 0x13        ; VGA 模式 0x13：320×200×8 位彩色（256 色）
        MOV     AH, 0x00        ; 功能号 0x00：设置显示模式
        INT     0x10            ; 调用 BIOS 视频中断
        ; 将显示模式参数保存到 BOOT_INFO 区域，供 C 语言内核引用
        MOV     BYTE [VMODE], 8     ; 保存色彩位数：8 位（256 色）
        MOV     WORD [SCRNX], 320   ; 保存水平分辨率：320
        MOV     WORD [SCRNY], 200   ; 保存垂直分辨率：200
        MOV     DWORD [VRAM], 0x000a0000  ; 保存显存基址：0xA0000

; -----------------------------------------------------------
; 获取键盘 LED 状态（从 BIOS 读取并保存）
; -----------------------------------------------------------
        MOV     AH, 0x02        ; 功能号 0x02：读取键盘标志字节（含 LED 状态）
        INT     0x16            ; 调用键盘 BIOS 中断
        MOV     [LEDS], AL      ; 将 LED 状态保存到 BOOT_INFO 区域

; -----------------------------------------------------------
; 暂时屏蔽 PIC（可编程中断控制器），禁止所有硬件中断
; 按照 AT 兼容机规范，如果要对 PIC 进行初始化，
; 必须在 CLI 之前先屏蔽 PIC，否则偶尔会挂死。
; PIC 的正式初始化稍后再做。
; -----------------------------------------------------------
        MOV     AL, 0xff        ; 所有位设为 1，屏蔽全部 IRQ
        OUT     0x21, AL        ; 写入主 PIC 的 IMR 寄存器（端口 0x21）
        NOP                     ; 连续 OUT 指令在某些机型上可能导致问题，插入 NOP 延迟
        OUT     0xa1, AL        ; 写入从 PIC 的 IMR 寄存器（端口 0xA1）

        CLI                     ; 禁止 CPU 级中断响应（清除 EFLAGS 的 IF 位）

; -----------------------------------------------------------
; 启用 A20 地址线，使 CPU 能够访问 1MB 以上的内存
; 通过键盘控制器（8042）的端口操作实现
; -----------------------------------------------------------
        CALL    waitkbdout      ; 等待键盘控制器输出缓冲区空闲
        MOV     AL, 0xd1        ; 命令 0xD1：准备向键盘控制器写输出端口
        OUT     0x64, AL        ; 发送命令到状态端口 0x64
        CALL    waitkbdout      ; 等待命令被接受
        MOV     AL, 0xdf        ; 数据 0xDF：设置输出端口 bit1 = 1（启用 A20）
        OUT     0x60, AL        ; 写入数据端口 0x60
        CALL    waitkbdout      ; 等待操作完成

; -----------------------------------------------------------
; 切换到保护模式（Protected Mode）
; -----------------------------------------------------------
[INSTRSET "i486p"]              ; 告知汇编器允许使用 486 指令集

        LGDT    [GDTR0]         ; 加载全局描述符表寄存器（GDTR），设置临时 GDT

        ; 修改 CR0 寄存器以启用保护模式
        MOV     EAX, CR0        ; 读取当前 CR0 值
        AND     EAX, 0x7fffffff ; 将 bit31（分页使能位）清零，禁止分页
        OR      EAX, 0x00000001 ; 将 bit0（保护模式使能位）置 1
        MOV     CR0, EAX        ; 写回 CR0，此时 CPU 进入保护模式

        ; 通过远跳转清空 CPU 流水线，确保后续指令在保护模式下正确解码
        JMP     pipelineflush
pipelineflush:

        ; 设置段寄存器，指向 GDT 中的第 1 个段描述符（可读写数据段，32 位）
        MOV     AX, 1*8         ; 段选择子：索引=1，TI=0（GDT），RPL=0
        MOV     DS, AX
        MOV     ES, AX
        MOV     FS, AX
        MOV     GS, AX
        MOV     SS, AX

; -----------------------------------------------------------
; 将 bootpack 从当前内存位置复制到目标地址 BOTPAK（0x280000）
; -----------------------------------------------------------
        MOV     ESI, bootpack   ; 源地址：bootpack 标签处（当前紧跟在本程序后的数据）
        MOV     EDI, BOTPAK     ; 目标地址：0x00280000
        MOV     ECX, 512*1024/4 ; 复制大小：512KB，以双字（4字节）为单位计数
        CALL    memcpy          ; 调用内存复制子程序

; -----------------------------------------------------------
; 将磁盘数据也转移到最终的内存位置（磁盘缓存区 DSKCAC）
; 首先复制引导扇区（IPL）
; -----------------------------------------------------------
        MOV     ESI, 0x7c00     ; 源地址：BIOS 加载 IPL 的固定地址 0x7C00
        MOV     EDI, DSKCAC     ; 目标地址：0x00100000（磁盘缓存区起始）
        MOV     ECX, 512/4      ; 复制 512 字节（一个扇区），以双字计数
        CALL    memcpy

; -----------------------------------------------------------
; 复制磁盘剩余的全部内容到缓存区
; -----------------------------------------------------------
        MOV     ESI, DSKCAC0+512    ; 源地址：实模式暂存区（0x8000）+512 字节偏移
        MOV     EDI, DSKCAC+512     ; 目标地址：磁盘缓存区（0x100000）+512 字节偏移
        MOV     ECX, 0
        MOV     CL, BYTE [CYLS]     ; 读取 IPL 探测到的柱面数
        ; 将柱面数转换为字节数：柱面数 × (磁头数2 × 每道扇区数18 × 512) / 4
        IMUL    ECX, 512*18*2/4     ; 得出总双字数
        SUB     ECX, 512/4          ; 减去 IPL 扇区（已单独复制），得到剩余数据量
        CALL    memcpy

; -----------------------------------------------------------
; asmhead 中必须完成的工作已全部结束，后续交给 bootpack 处理
; 下面根据 bootpack 的 ELF 头信息进行段重定位，然后跳转执行
; -----------------------------------------------------------

; -----------------------------------------------------------
; 处理 bootpack 的重定位信息（根据 ELF 程序头进行内存复制）
; -----------------------------------------------------------
        MOV     EBX, BOTPAK          ; EBX = bootpack 基址（0x280000）
        MOV     ECX, [EBX+16]        ; ECX = ELF 头中 .p_filesz 字段（段的文件大小）
        ADD     ECX, 3               ; ECX += 3（向上取整对齐到 4 字节边界）
        SHR     ECX, 2               ; ECX /= 4（将字节数转换为双字数）
        JZ      skip                 ; 如果大小为 0，跳过复制（无需重定位）
        MOV     ESI, [EBX+20]        ; 源地址 = bootpack 基址 + .p_offset 字段
        ADD     ESI, EBX
        MOV     EDI, [EBX+12]        ; 目标地址 = .p_vaddr 字段（虚拟地址）
        CALL    memcpy               ; 执行段复制
skip:
; -----------------------------------------------------------
; 设置栈指针，然后通过远跳转将控制权交给 bootpack 入口代码
; -----------------------------------------------------------
        MOV     ESP, [EBX+12]        ; 从 ELF 头中读取入口所需的初始栈地址（.p_vaddr）
        JMP     DWORD 2*8:0x0000001b ; 远跳转到代码段（选择子 2*8）+ 偏移 0x1B
                                      ; 选择子 2*8 指向 GDT 中第 2 项（可执行段，32bit）

; ============================================================
; 子程序：等待键盘控制器输出缓冲区空闲
; ============================================================
waitkbdout:
        IN      AL, 0x64            ; 读取键盘控制器状态端口 0x64
        AND     AL, 0x02            ; 测试 bit1（输入缓冲区满标志）
        JNZ     waitkbdout          ; 若不为 0，表示缓冲区仍忙，继续等待
        RET

; ============================================================
; 子程序：内存复制（以双字为单位，一次复制 4 字节）
; 参数：ESI = 源地址，EDI = 目标地址，ECX = 双字数
; 注意：此实现未考虑地址前缀，在使用字符串指令后可用更高效的写法
; ============================================================
memcpy:
        MOV     EAX, [ESI]          ; 从源地址读取一个双字（4 字节）
        ADD     ESI, 4              ; 源指针前移 4 字节
        MOV     [EDI], EAX          ; 写入到目标地址
        ADD     EDI, 4              ; 目标指针前移 4 字节
        SUB     ECX, 1              ; 计数器减 1
        JNZ     memcpy              ; 若未复制完（ECX != 0），继续循环
        RET

; ============================================================
; 全局描述符表（GDT）
; ============================================================
        ALIGNB  16                  ; 16 字节对齐
GDT0:
        RESB    8                   ; 第 0 项：空描述符（CPU 要求必须存在）
        ; 第 1 项：数据段描述符（可读写，32 位）
        ; 基址=0，界限=0xFFFFF，DPL=0，G=1（4KB 粒度）→ 覆盖整个 4GB 地址空间
        DW      0xffff, 0x0000, 0x9200, 0x00cf
        ; 第 2 项：代码段描述符（可执行，32 位，供 bootpack 使用）
        ; 基址=0，界限=0xFFFFF，DPL=0，G=1（4KB 粒度）
        DW      0xffff, 0x0000, 0x9a28, 0x0047

        DW      0                   ; 结束标记（GDT 边界用）
GDTR0:
        DW      8*3-1               ; GDT 界限 = 表总字节数 - 1（3 个描述符 × 8 - 1）
        DD      GDT0                ; GDT 基址（线性地址）

        ALIGNB  16
bootpack:                           ; bootpack 二进制数据（由链接器附加在此标签之后）